{
  "name": "linktree-custom-domain",
  "version": "1.0.0",
  "description": "Custom domain proxy for Linktree profiles",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "check": "bun lint && tsc --noEmit",
    "lint": "eslint .",
    "f": "(git diff --name-only --diff-filter=ACMR HEAD && git ls-files --others --exclude-standard) | grep -E '\\.(ts|tsx|js|jsx|json|css|md|mjs)$' | xargs bunx prettier --write --ignore-unknown",
    "f:all": "prettier --write .",
    "f:check": "prettier --check .",
    "prepare": "test -d .git && husky || true"
  },
  "author": "vikshan",
  "license": "ISC",
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "elysia": "^1.4.27"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/bun": "^1.3.10",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "conventional-changelog-gitmoji": "^0.2.5",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "semantic-release-gitmoji": "^1.6.9",
    "typescript-eslint": "^8.57.0"
  }
}
