{
  "name": "Ubuntu + Bun",
  "image": "vikshan/ubuntu-bun:latest",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {
      "installDirectlyFromGitHubRelease": true,
      "version": "latest"
    }
  },
  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "WakaTime.vscode-wakatime",
        "GitHub.copilot",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        "oven.bun-vscode",
        "coderabbit.coderabbit-vscode"
      ]
    }
  },

  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": "sudo apt update && sudo apt upgrade -y && [ -f scripts/git.sh ] && chmod +x scripts/git.sh; bun install && sudo ln -sf /usr/share/zoneinfo/Africa/Nairobi /etc/localtime && curl -fsSL https://cli.coderabbit.ai/install.sh | sh",

  // Set `remoteUser` to `root` to connect as root.
  "remoteUser": "root"
}
